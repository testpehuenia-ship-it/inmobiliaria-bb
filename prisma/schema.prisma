generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  role       String     @default("AGENT")
  phone      String?
  avatarUrl  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  properties Property[]
}

model Property {
  id            String    @id @default(cuid())
  title         String
  description   String
  price         Float
  currency      String    @default("USD")
  operationType String
  propertyType  String
  status        String    @default("DISPONIBLE")
  bedrooms      Int       @default(0)
  bathrooms     Int       @default(0)
  totalArea     Float     @default(0)
  coveredArea   Float     @default(0)
  city          String
  neighborhood  String?
  address       String?
  isFeatured    Boolean   @default(false)
  isNewArrival  Boolean   @default(false)
  agentId       String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  images        Image[]
  inquiries     Inquiry[]
  agent         User      @relation(fields: [agentId], references: [id])
}

model Image {
  id         String   @id @default(cuid())
  url        String
  isMain     Boolean  @default(false)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id            String    @id @default(cuid())
  nombre        String
  email         String
  telefono      String
  mensaje       String
  propertyId    String?
  propertyTitle String?
  isRead        Boolean   @default(false)
  
  // Campos extra para Tasaciones
  type          String   @default("CONSULTA") // CONSULTA, CONTACTO, TASACION
  propertyType  String?
  bedrooms      Int?
  bathrooms     Int?
  area          Float?
  address       String?
  
  createdAt     DateTime  @default(now())
  property      Property? @relation(fields: [propertyId], references: [id])
}
